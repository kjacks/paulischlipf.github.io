---
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/translations';
const t = useTranslations('de');

const works = (await getCollection('works', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t('works.title')}</title>
  </head>
  <body>
    <nav>
      <a href="/de">{t('nav.home')}</a>
      <a href="/de/works">{t('nav.works')}</a>
      <a href="/de/installations">{t('nav.installations')}</a>
      <a href="/works" lang="en">English</a>
    </nav>

    <main>
      <h1>{t('works.title')}</h1>
      <ul>
        {works.map((work) => (
          <li>
            <a href={`/de/works/${work.id}`}>
              <strong>{work.data.title_de}</strong>
              {work.data.medium_de && <span> — {work.data.medium_de}</span>}
            </a>
            <p>{work.data.description_de}</p>
            <time>{work.data.date.toLocaleDateString('de-DE', { year: 'numeric', month: 'long' })}</time>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
