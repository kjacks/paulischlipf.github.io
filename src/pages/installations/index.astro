---
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/translations';
const t = useTranslations('en');

const installations = (await getCollection('installations', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t('installations.title')}</title>
  </head>
  <body>
    <nav>
      <a href="/">{t('nav.home')}</a>
      <a href="/works">{t('nav.works')}</a>
      <a href="/installations">{t('nav.installations')}</a>
      <a href="/de/installations" lang="de">Deutsch</a>
    </nav>

    <main>
      <h1>{t('installations.title')}</h1>
      <ul>
        {installations.map((installation) => (
          <li>
            <a href={`/installations/${installation.id}`}>
              <strong>{installation.data.title_en}</strong>
              {installation.data.location_en && <span> — {installation.data.location_en}</span>}
            </a>
            <p>{installation.data.description_en}</p>
            <time>{installation.data.date.toLocaleDateString('en-AU', { year: 'numeric', month: 'long' })}</time>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
