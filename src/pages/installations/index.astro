---
import { getCollection } from 'astro:content';

const installations = (await getCollection('installations', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Installations</title>
  </head>
  <body>
    <nav>
      <a href="/">Home</a>
      <a href="/works">Works</a>
      <a href="/installations">Installations</a>
    </nav>

    <main>
      <h1>Installations</h1>
      <ul>
        {installations.map((installation) => (
          <li>
            <a href={`/installations/${installation.id}`}>
              <strong>{installation.data.title}</strong>
              {installation.data.location && <span> — {installation.data.location}</span>}
            </a>
            <p>{installation.data.description}</p>
            <time>{installation.data.date.toLocaleDateString('en-AU', { year: 'numeric', month: 'long' })}</time>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
