---
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../i18n/translations';

export async function getStaticPaths() {
  const works = await getCollection('works', ({ data }) => !data.draft);
  return works.map((work) => ({
    params: { slug: work.id },
    props: { work },
  }));
}

const { work } = Astro.props;
const { Content } = await render(work);
const t = useTranslations('en');
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={work.data.description_en} />
    <title>{work.data.title_en}</title>
  </head>
  <body>
    <nav>
      <a href="/">{t('nav.home')}</a>
      <a href="/works">{t('nav.works')}</a>
      <a href="/installations">{t('nav.installations')}</a>
      <a href={`/de/works/${work.id}`} lang="de">Deutsch</a>
    </nav>

    <main>
      <a href="/works">{t('works.back')}</a>
      <article>
        <header>
          <h1>{work.data.title_en}</h1>
          <p>{work.data.description_en}</p>
          <dl>
            {work.data.medium_en && (
              <>
                <dt>{t('label.medium')}</dt>
                <dd>{work.data.medium_en}</dd>
              </>
            )}
            <dt>{t('label.date')}</dt>
            <dd>
              <time>{work.data.date.toLocaleDateString('en-AU', { year: 'numeric', month: 'long' })}</time>
            </dd>
          </dl>
          {work.data.tags.length > 0 && (
            <ul>
              {work.data.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          )}
        </header>
        {work.data.image && <img src={work.data.image} alt={work.data.title_en} />}
        <Content />
      </article>
    </main>
  </body>
</html>
