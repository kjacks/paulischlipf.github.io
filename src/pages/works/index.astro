---
import { getCollection } from 'astro:content';

const works = (await getCollection('works', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Works</title>
  </head>
  <body>
    <nav>
      <a href="/">Home</a>
      <a href="/works">Works</a>
      <a href="/installations">Installations</a>
    </nav>

    <main>
      <h1>Works</h1>
      <ul>
        {works.map((work) => (
          <li>
            <a href={`/works/${work.id}`}>
              <strong>{work.data.title}</strong>
              {work.data.medium && <span> — {work.data.medium}</span>}
            </a>
            <p>{work.data.description}</p>
            <time>{work.data.date.toLocaleDateString('en-AU', { year: 'numeric', month: 'long' })}</time>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
