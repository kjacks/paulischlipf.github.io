---
import { getCollection, render } from "astro:content";
import { marked } from "marked";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  useTranslations,
  localePath,
  alternateLang,
  dateLocales,
  type Lang,
} from "../../../i18n/translations";

export async function getStaticPaths() {
  const paintings = await getCollection("paintings", ({ data }) => !data.draft);
  const locales = [
    { lang: "en" as const, langParam: undefined },
    { lang: "de" as const, langParam: "de" },
  ];
  return locales.flatMap(({ lang, langParam }) =>
    paintings.map((painting) => ({
      params: { lang: langParam, slug: painting.id },
      props: { painting, lang },
    })),
  );
}

const { painting, lang } = Astro.props as { painting: any; lang: Lang };
const t = useTranslations(lang);
const prefix = localePath(lang);
const { Content } = await render(painting);
const title = lang === "en" ? painting.data.title_en : painting.data.title_de;
const description =
  lang === "en" ? painting.data.description_en : painting.data.description_de;
const medium =
  lang === "en" ? painting.data.medium_en : painting.data.medium_de;
const bodyDeHtml =
  lang === "de" ? marked.parse(painting.data.body_de ?? "") : "";
---

<SiteLayout
  {lang}
  {title}
  {description}
  altHref={`${localePath(alternateLang(lang))}/paintings/${painting.id}`}
>
  <main>
    <article>
      <header>
        <h1>{title}</h1>
        <p>{description}</p>
        <dl>
          {
            medium && (
              <>
                <dt>{t("label.medium")}</dt>
                <dd>{medium}</dd>
              </>
            )
          }
          <dt>{t("label.date")}</dt>
          <dd>
            <time>
              {
                painting.data.date.toLocaleDateString(dateLocales[lang], {
                  year: "numeric",
                  month: "long",
                })
              }
            </time>
          </dd>
        </dl>
        {
          painting.data.tags.length > 0 && (
            <ul>
              {painting.data.tags.map((tag: string) => (
                <li>{tag}</li>
              ))}
            </ul>
          )
        }
      </header>
      {painting.data.image && <img src={painting.data.image} alt={title} />}
    </article>
  </main>
</SiteLayout>
