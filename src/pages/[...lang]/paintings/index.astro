---
import { getCollection } from "astro:content";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  useTranslations,
  localePath,
  alternateLang,
  dateLocales,
} from "../../../i18n/translations";
import Gallery from "../../../components/Gallery.svelte";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: "en" as const } },
    { params: { lang: "de" }, props: { lang: "de" as const } },
  ];
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const prefix = localePath(lang);

const paintings = (await getCollection("paintings")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<SiteLayout
  lang={lang}
  title={t("paintings.title")}
  altHref={`${localePath(alternateLang(lang))}/paintings`}
>
  <main>
    <h1>{t("paintings.title")}</h1>
    <Gallery items={paintings} {lang} />
  </main>
</SiteLayout>
