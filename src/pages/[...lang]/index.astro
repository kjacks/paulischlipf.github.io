---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { localePath, alternateLang, type Lang } from "../../i18n/translations";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: "en" as const } },
    { params: { lang: "de" }, props: { lang: "de" as const } },
  ];
}

const { lang } = Astro.props as { lang: Lang };
---

<SiteLayout
  lang={lang}
  title="Pauli Schlipf"
  altHref={`${localePath(alternateLang(lang))}/`}
>
  <main>
    <h1>Pauli Schlipf</h1>
  </main>
</SiteLayout>
