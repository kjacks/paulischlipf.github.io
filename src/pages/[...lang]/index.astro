---
import { localePath, type Lang } from "../../i18n/translations";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: "en" as const } },
    { params: { lang: "de" }, props: { lang: "de" as const } },
  ];
}

const { lang } = Astro.props as { lang: Lang };

return Astro.redirect(`${localePath(lang)}/paintings`, 301);
---
