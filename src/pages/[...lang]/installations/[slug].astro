---
import { getCollection, render } from "astro:content";
import { marked } from "marked";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  useTranslations,
  localePath,
  alternateLang,
  dateLocales,
  type Lang,
} from "../../../i18n/translations";

export async function getStaticPaths() {
  const installations = await getCollection(
    "installations",
    ({ data }) => !data.draft,
  );
  const locales = [
    { lang: "en" as const, langParam: undefined },
    { lang: "de" as const, langParam: "de" },
  ];
  return locales.flatMap(({ lang, langParam }) =>
    installations.map((installation) => ({
      params: { lang: langParam, slug: installation.id },
      props: { installation, lang },
    })),
  );
}

const { installation, lang } = Astro.props as { installation: any; lang: Lang };
const t = useTranslations(lang);
const prefix = localePath(lang);
const { Content } = await render(installation);
const title =
  lang === "en" ? installation.data.title_en : installation.data.title_de;
const description =
  lang === "en"
    ? installation.data.description_en
    : installation.data.description_de;
const location =
  lang === "en" ? installation.data.location_en : installation.data.location_de;
---

<SiteLayout
  {lang}
  {title}
  {description}
  altHref={`${localePath(alternateLang(lang))}/installations/${installation.id}`}
>
  <main>
    <a href={`${prefix}/installations`}>{t("installations.back")}</a>
    <article>
      <header>
        <h1>{title}</h1>
        <p>{description}</p>
        <dl>
          {
            location && (
              <>
                <dt>{t("label.location")}</dt>
                <dd>{location}</dd>
              </>
            )
          }
          <dt>{t("label.date")}</dt>
          <dd>
            <time>
              {
                installation.data.date.toLocaleDateString(dateLocales[lang], {
                  year: "numeric",
                  month: "long",
                })
              }
            </time>
          </dd>
        </dl>
        {
          installation.data.tags.length > 0 && (
            <ul>
              {installation.data.tags.map((tag: string) => (
                <li>{tag}</li>
              ))}
            </ul>
          )
        }
      </header>
      {
        installation.data.image && (
          <img src={installation.data.image} alt={title} />
        )
      }
    </article>
  </main>
</SiteLayout>
