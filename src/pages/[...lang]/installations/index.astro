---
import { getCollection } from "astro:content";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  useTranslations,
  localePath,
  alternateLang,
  getLocalizedObject,
  dateLocales,
} from "../../../i18n/translations";
import FloatingGallery from "../../../components/FloatingGallery.svelte";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: "en" as const } },
    { params: { lang: "de" }, props: { lang: "de" as const } },
  ];
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const prefix = localePath(lang);

const installations = (await getCollection("installations"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((item) => ({ ...item, data: getLocalizedObject(item.data, lang) }));
---

<SiteLayout
  lang={lang}
  title={t("installations.title")}
  altHref={`${localePath(alternateLang(lang))}/installations`}
>
  <main>
    <FloatingGallery items={installations} client:load />
  </main>
</SiteLayout>
