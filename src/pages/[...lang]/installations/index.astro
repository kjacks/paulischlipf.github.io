---
import { getCollection } from "astro:content";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  useTranslations,
  localePath,
  alternateLang,
  dateLocales,
  type Lang,
} from "../../../i18n/translations";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: "en" as const } },
    { params: { lang: "de" }, props: { lang: "de" as const } },
  ];
}

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
const prefix = localePath(lang);

const installations = (
  await getCollection("installations", ({ data }) => !data.draft)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<SiteLayout
  lang={lang}
  title={t("installations.title")}
  altHref={`${localePath(alternateLang(lang))}/installations`}
>
  <main>
    <h1>{t("installations.title")}</h1>
    <ul>
      {
        installations.map((installation) => (
          <li>
            <a href={`${prefix}/installations/${installation.id}`}>
              <strong>
                {lang === "en"
                  ? installation.data.title_en
                  : installation.data.title_de}
              </strong>
              {lang === "en"
                ? installation.data.location_en && (
                    <span> — {installation.data.location_en}</span>
                  )
                : installation.data.location_de && (
                    <span> — {installation.data.location_de}</span>
                  )}
            </a>
            <p>
              {lang === "en"
                ? installation.data.description_en
                : installation.data.description_de}
            </p>
            <time>
              {installation.data.date.toLocaleDateString(dateLocales[lang], {
                year: "numeric",
                month: "long",
              })}
            </time>
          </li>
        ))
      }
    </ul>
  </main>
</SiteLayout>
