---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  useTranslations,
  localePath,
  alternateLang,
  getLocalizedObject,
  dateLocales,
} from "../../../i18n/translations";
import InstallationList from "../../../components/InstallationList.svelte";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: "en" as const } },
    { params: { lang: "de" }, props: { lang: "de" as const } },
  ];
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const prefix = localePath(lang);

const installations = await Promise.all(
  (await getCollection("installations"))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .map(async (rawItem) => {
      const data = getLocalizedObject(rawItem.data, lang);
      if (data.images) {
        data.images = await Promise.all(
          data.images.map(async (img) => {
            const result = await getImage({
              src: img,
              format: "webp",
              width: 800,
            });
            return {
              src: result.src,
              width: result.attributes.width,
              height: result.attributes.height,
            };
          }),
        );
      }
      return { ...rawItem, data };
    }),
);
---

<SiteLayout
  lang={lang}
  title={t("installations.title")}
  altHref={`${localePath(alternateLang(lang))}/installations`}
  class="max-w-none"
>
  <InstallationList items={installations} client:load />
</SiteLayout>
