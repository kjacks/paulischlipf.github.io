---
import { getCollection, render } from 'astro:content';
import { marked } from 'marked';
import { useTranslations, localePath, alternateLang, languages, type Lang } from '../../i18n/translations';

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: 'en' as const } },
    { params: { lang: 'de' }, props: { lang: 'de' as const } },
  ];
}

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
const prefix = localePath(lang);
const altLang = alternateLang(lang);
const altPrefix = localePath(altLang);

const entries = await getCollection('contact');
const entry = entries[0];
const { Content } = await render(entry);
const title = lang === 'en' ? entry.data.title_en : entry.data.title_de;
const bodyDeHtml = lang === 'de' ? marked.parse(entry.data.body_de ?? '') : '';
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Pauli Schlipf</title>
  </head>
  <body>
    <nav>
      <a href={`${prefix}/`}>{t('nav.home')}</a>
      <a href={`${prefix}/works`}>{t('nav.works')}</a>
      <a href={`${prefix}/installations`}>{t('nav.installations')}</a>
      <a href={`${prefix}/bio`}>{t('nav.bio')}</a>
      <a href={`${prefix}/contact`}>{t('nav.contact')}</a>
      <a href={`${altPrefix}/contact`} lang={altLang}>{languages[altLang]}</a>
    </nav>
    <main>
      <h1>{title}</h1>
      {lang === 'en' ? <Content /> : <div set:html={bodyDeHtml} />}
      {entry.data.email && (
        <p><a href={`mailto:${entry.data.email}`}>{entry.data.email}</a></p>
      )}
    </main>
  </body>
</html>
