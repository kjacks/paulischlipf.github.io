---
import { getCollection, render } from "astro:content";
import { marked } from "marked";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { localePath, alternateLang, type Lang } from "../../i18n/translations";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: "en" as const } },
    { params: { lang: "de" }, props: { lang: "de" as const } },
  ];
}

const { lang } = Astro.props as { lang: Lang };
const entries = await getCollection("contact");
const entry = entries[0];
const { Content } = await render(entry);
const title = lang === "en" ? entry.data.title_en : entry.data.title_de;
const bodyDeHtml = lang === "de" ? marked.parse(entry.data.body_de ?? "") : "";
---

<SiteLayout lang={lang} title={`${title} — Pauli Schlipf`} altHref={`${localePath(alternateLang(lang))}/contact`}>
  <main>
    <h1>{title}</h1>
    {lang === "en" ? <Content /> : <div set:html={bodyDeHtml} />}
    {entry.data.email && (
      <p><a href={`mailto:${entry.data.email}`}>{entry.data.email}</a></p>
    )}
  </main>
</SiteLayout>
