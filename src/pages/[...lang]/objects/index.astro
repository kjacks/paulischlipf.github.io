---
import { getCollection } from "astro:content";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  useTranslations,
  localePath,
  alternateLang,
  dateLocales,
  type Lang,
} from "../../../i18n/translations";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: "en" as const } },
    { params: { lang: "de" }, props: { lang: "de" as const } },
  ];
}

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
const prefix = localePath(lang);

const objects = (
  await getCollection("objects", ({ data }) => !data.draft)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<SiteLayout
  lang={lang}
  title={t("objects.title")}
  altHref={`${localePath(alternateLang(lang))}/objects`}
>
  <main>
    <h1>{t("objects.title")}</h1>
    <ul>
      {
        objects.map((object) => (
          <li>
            <a href={`${prefix}/objects/${object.id}`}>
              <strong>
                {lang === "en" ? object.data.title_en : object.data.title_de}
              </strong>
              {lang === "en"
                ? object.data.medium_en && (
                    <span> — {object.data.medium_en}</span>
                  )
                : object.data.medium_de && (
                    <span> — {object.data.medium_de}</span>
                  )}
            </a>
            <p>
              {lang === "en"
                ? object.data.description_en
                : object.data.description_de}
            </p>
            <time>
              {object.data.date.toLocaleDateString(dateLocales[lang], {
                year: "numeric",
                month: "long",
              })}
            </time>
          </li>
        ))
      }
    </ul>
  </main>
</SiteLayout>
