---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  useTranslations,
  localePath,
  alternateLang,
  getLocalizedObject,
  dateLocales,
} from "../../../i18n/translations";
import Carousel3D from "../../../components/Carousel3D.svelte";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: "en" as const } },
    { params: { lang: "de" }, props: { lang: "de" as const } },
  ];
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const prefix = localePath(lang);

const objects = await Promise.all(
  (await getCollection("objects"))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .map(async (rawItem) => {
      const data = getLocalizedObject(rawItem.data, lang);
      if (data.image) {
        const [thumbnail, full] = await Promise.all([
          getImage({ src: data.image, format: "webp", width: 400 }),
          getImage({ src: data.image, format: "webp", width: 1200 }),
        ]);
        (data as any).image = {
          thumbnail: { src: thumbnail.src, width: thumbnail.attributes.width, height: thumbnail.attributes.height },
          full: { src: full.src, width: full.attributes.width, height: full.attributes.height },
        };
      }
      return { ...rawItem, data };
    }),
);
---

<SiteLayout
  lang={lang}
  title={t("objects.title")}
  altHref={`${localePath(alternateLang(lang))}/objects`}
>
  <main>
    <Carousel3D items={objects} client:load />
  </main>
</SiteLayout>
