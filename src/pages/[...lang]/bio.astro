---
import { getCollection, render } from "astro:content";
import { marked } from "marked";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { localePath, alternateLang, type Lang } from "../../i18n/translations";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: "en" as const } },
    { params: { lang: "de" }, props: { lang: "de" as const } },
  ];
}

const { lang } = Astro.props as { lang: Lang };
const entries = await getCollection("bio");
const entry = entries[0];
const { Content } = await render(entry);
const title = lang === "en" ? entry.data.title_en : entry.data.title_de;
const bodyDeHtml = lang === "de" ? marked.parse(entry.data.body_de ?? "") : "";
---

<SiteLayout
  lang={lang}
  title={`${title} — Pauli Schlipf`}
  altHref={`${localePath(alternateLang(lang))}/bio`}
>
  <main>
    <h1>{title}</h1>
    {entry.data.image && <img src={entry.data.image} alt={title} />}
    {lang === "en" ? <Content /> : <div set:html={bodyDeHtml} />}
  </main>
</SiteLayout>
