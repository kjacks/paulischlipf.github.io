---
import { getCollection, render } from "astro:content";
import { marked } from "marked";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { localePath, alternateLang, type Lang } from "../../i18n/translations";
import { Image } from "astro:assets";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: "en" as const } },
    { params: { lang: "de" }, props: { lang: "de" as const } },
  ];
}

const { lang } = Astro.props as { lang: Lang };
const entries = await getCollection("bio");
const entry = entries[0];
const title = lang === "en" ? entry.data.title_en : entry.data.title_de;
const bodyHtml =
  lang === "en"
    ? marked.parse(entry.data.body_en ?? "")
    : marked.parse(entry.data.body_de ?? "");
---

<SiteLayout
  lang={lang}
  title={`${title} — Pauli Schlipf`}
  altHref={`${localePath(alternateLang(lang))}/bio`}
>
  <main>
    <div class="md:flex gap-8 my-8">
      {
        entry.data.image && (
          <div class="flex-1">
            <Image
              src={entry.data.image}
              alt={title}
              width={400}
              height={400}
              class="w-full h-auto object-cover rounded"
            />
          </div>
        )
      }
      <div class="flex-1">
        <h1 class="text-2xl font-bold">{title}</h1>
        <div class="my-8" set:html={bodyHtml} />
      </div>
    </div>
  </main>
</SiteLayout>
