---
import { getCollection, render } from "astro:content";
import { marked } from "marked";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  useTranslations,
  localePath,
  alternateLang,
  dateLocales,
  type Lang,
} from "../../../i18n/translations";

export async function getStaticPaths() {
  const works = await getCollection("works", ({ data }) => !data.draft);
  const locales = [
    { lang: "en" as const, langParam: undefined },
    { lang: "de" as const, langParam: "de" },
  ];
  return locales.flatMap(({ lang, langParam }) =>
    works.map((work) => ({
      params: { lang: langParam, slug: work.id },
      props: { work, lang },
    })),
  );
}

const { work, lang } = Astro.props as { work: any; lang: Lang };
const t = useTranslations(lang);
const prefix = localePath(lang);
const { Content } = await render(work);
const title = lang === "en" ? work.data.title_en : work.data.title_de;
const description =
  lang === "en" ? work.data.description_en : work.data.description_de;
const medium = lang === "en" ? work.data.medium_en : work.data.medium_de;
const bodyDeHtml = lang === "de" ? marked.parse(work.data.body_de ?? "") : "";
---

<SiteLayout
  {lang}
  {title}
  {description}
  altHref={`${localePath(alternateLang(lang))}/works/${work.id}`}
>
  <main>
    <a href={`${prefix}/works`}>{t("works.back")}</a>
    <article>
      <header>
        <h1>{title}</h1>
        <p>{description}</p>
        <dl>
          {
            medium && (
              <>
                <dt>{t("label.medium")}</dt>
                <dd>{medium}</dd>
              </>
            )
          }
          <dt>{t("label.date")}</dt>
          <dd>
            <time>
              {
                work.data.date.toLocaleDateString(dateLocales[lang], {
                  year: "numeric",
                  month: "long",
                })
              }
            </time>
          </dd>
        </dl>
        {
          work.data.tags.length > 0 && (
            <ul>
              {work.data.tags.map((tag: string) => (
                <li>{tag}</li>
              ))}
            </ul>
          )
        }
      </header>
      {work.data.image && <img src={work.data.image} alt={title} />}
      {lang === "en" ? <Content /> : <div set:html={bodyDeHtml} />}
    </article>
  </main>
</SiteLayout>
