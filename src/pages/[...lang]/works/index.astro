---
import { getCollection } from "astro:content";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  useTranslations,
  localePath,
  alternateLang,
  dateLocales,
  type Lang,
} from "../../../i18n/translations";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: "en" as const } },
    { params: { lang: "de" }, props: { lang: "de" as const } },
  ];
}

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
const prefix = localePath(lang);

const works = (await getCollection("works", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<SiteLayout
  lang={lang}
  title={t("works.title")}
  altHref={`${localePath(alternateLang(lang))}/works`}
>
  <main>
    <h1>{t("works.title")}</h1>
    <ul>
      {
        works.map((work) => (
          <li>
            <a href={`${prefix}/works/${work.id}`}>
              <strong>
                {lang === "en" ? work.data.title_en : work.data.title_de}
              </strong>
              {lang === "en"
                ? work.data.medium_en && <span> — {work.data.medium_en}</span>
                : work.data.medium_de && <span> — {work.data.medium_de}</span>}
            </a>
            <p>
              {lang === "en"
                ? work.data.description_en
                : work.data.description_de}
            </p>
            <time>
              {work.data.date.toLocaleDateString(dateLocales[lang], {
                year: "numeric",
                month: "long",
              })}
            </time>
          </li>
        ))
      }
    </ul>
  </main>
</SiteLayout>
