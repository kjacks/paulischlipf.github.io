---
import { getCollection } from "astro:content";
import ImageCollage from "../components/ImageCollage.astro";

const bioEntries = await getCollection("bio");
const bio = bioEntries[0];
const contactEntries = await getCollection("contact");
const contact = contactEntries[0];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pauli Schlipf</title>
  </head>
  <body>
    <main>
      <ImageCollage dir="/images" />
      <div class="name-box">
        <h1>Pauli Schlipf</h1>
      </div>
      <div class="links">
        <a
          href="https://www.instagram.com/paulischlipf/"
          target="_blank"
          rel="noopener noreferrer">Instagram</a
        >
        <a href={`mailto:paulischlipf@web.de`}>Email</a>
      </div>
    </main>
  </body>
</html>

<style lang="scss">
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  body {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: futura-pt, sans-serif;
  }
  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem;
  }
  .name-box {
    text-align: center;
  }
  .name-box h1 {
    letter-spacing: 0.05em;
    font-weight: bold;
    font-size: 3rem;
  }
  .links {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .links a {
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid currentColor;
  }
  .links a:hover {
    opacity: 0.6;
  }
</style>
