---
import type { Lang } from "../i18n/translations";
import {
  useTranslations,
  localePath,
  alternateLang,
  languages,
} from "../i18n/translations";

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  altHref: string;
}

const { lang, title, description, altHref } = Astro.props;
const t = useTranslations(lang);
const prefix = localePath(lang);
const altLang = alternateLang(lang);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <a href={`${prefix}/`}>{t("nav.home")}</a>
      <a href={`${prefix}/paintings`}>{t("nav.paintings")}</a>
      <a href={`${prefix}/objects`}>{t("nav.objects")}</a>
      <a href={`${prefix}/installations`}>{t("nav.installations")}</a>
      <a href={`${prefix}/bio`}>{t("nav.bio")}</a>
      <a href={`${prefix}/contact`}>{t("nav.contact")}</a>
      <a href={altHref} lang={altLang}>{languages[altLang]}</a>
    </nav>
    <slot />
  </body>
</html>
